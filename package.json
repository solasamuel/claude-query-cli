{
  "name": "claude-query",
  "version": "0.1.0",
  "description": "Natural language queries against any data source via Claude API",
  "type": "module",
  "bin": {
    "claude-query": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Sola Samuel / Spearhead Finance Ltd",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "node-sql-parser": "^5.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
